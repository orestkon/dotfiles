{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/big-pickle",
  "small_model": "ollama/big-pickle",
  "agent": {
    "plan": {
"model": "ollama/big-pickle"
      },
      "build": {
        "model": "ollama/big-pickle"
    }
  },
  "provider": {
    "google": {
      "options": {
        "apiKey": "{file:~/.gemini_key}"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "qwen2.5-coder:14b-16k": {},
        "qwen2.5-coder:14b": {}
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "glob": "allow"
  }
}
