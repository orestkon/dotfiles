{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-flash",
  "small_model": "google/gemini-2.5-flash",
  "agent": {
    "plan": {
      "model": "google/gemini-2.5-flash"
    },
    "build": {
      "model": "google/gemini-2.5-flash"
    }
  },
  "provider": {
    "google": {
      "options": {
        "apiKey": "{file:~/.gemini_key}"
      }
    }
  },
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "read": "allow",
    "glob": "allow"
  }
}
