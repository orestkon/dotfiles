# ==============================================================================
# GRUVBOX MATERIAL MASTER PALETTE
# ------------------------------------------------------------------------------
# Background (Hard): #1d2021 | Foreground: #d4be98
# ------------------------------------------------------------------------------
# Red:    #ea6962  |  Orange: #e78a4e  |  Yellow: #d8a657
# Green:  #a9b665  |  Aqua:   #89b482  |  Blue:   #7daea3
# Purple: #d3869b  |  Gray:   #928374  |  Beige:  #a89984
# ==============================================================================

[flavor]
use   = "gruvbox-dark"
dark  = "gruvbox-dark"
light = "gruvbox-dark"

[manager]
# --- Navigation ---
# The path at the top (using Material Aqua)
cwd = { fg = "#89b482" } 

# --- The Cursor ---
# Material Yellow background with dark text
hovered         = { fg = "#282828", bg = "#d8a657", bold = true }
preview_hovered = { underline = true }

# --- Selection Mode ---
# Material Green for when you select multiple files
selection       = { fg = "#282828", bg = "#a9b665" }

# --- Default Text ---
# The "Foreground" color—softer than pure white
default = { fg = "#d4be98" }

[filetype]
rules = [
    # 1. DIRECTORIES
    # Using the "Steel Blue" Material color for a clean, professional look
    { name = "*/", fg = "#7daea3", bold = true },

    # 2. CONFIGURATION & SCRIPTS
    { name = "*.lua",  fg = "#d8a657" }, # Material Yellow (Matches your Nvim)
    { name = "*.toml", fg = "#e78a4e" }, # Material Orange
    { name = "*.json", fg = "#e78a4e" },
    { name = "*.sh",   fg = "#a9b665" }, # Material Green
    { name = "*.zsh",  fg = "#a9b665" },

    # 3. CODING LANGUAGES
    { name = "*.py",   fg = "#a9b665" }, # Green
    { name = "*.js",   fg = "#d8a657" }, # Yellow
    { name = "*.rs",   fg = "#e78a4e" }, # Orange

    # 4. MEDIA & DOCUMENTS
    { mime = "image/*", fg = "#d3869b" }, # Material Purple
    { mime = "video/*", fg = "#d3869b" },
    { name = "*.md",    fg = "#a89984" }, # Muted Beige for markdown
    { name = "*.pdf",   fg = "#ea6962" }, # Material Red

    # 5. BUILD & SYSTEM
    { name = "Makefile",   fg = "#ea6962" },
    { name = ".gitignore", fg = "#928374" }, # Subtle Gray
    { name = ".git/",      fg = "#ea6962" },
]
